# Public ports
FRONTEND_PORT=3037
BACKEND_PORT=8047

# Admin login for /admin
ADMIN_USER=admin
ADMIN_PASS=change-this-password
ADMIN_SECRET=change-this-to-a-long-random-string

# Email notification (optional)
# SMTP_SECURE=true means implicit TLS, usually port 465.
# SMTP_SECURE=false means STARTTLS, usually port 587.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@top-marine.cn
MAIL_TO=admin@top-marine.cn
