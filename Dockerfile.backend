# TOP MARINE GROUP — standalone Node backend (CSRF, cookies, careers) ─────────
FROM node:22-alpine
WORKDIR /app
COPY package.json ./
# only runtime dep is busboy; node:sqlite is built into Node 22
RUN npm install busboy@^1.6.0 --no-audit --no-fund
COPY server ./server
ENV BACKEND_PORT=8047
EXPOSE 8047
# data/ (sqlite db + resume files + outbox) is a mounted volume
CMD ["node", "server/backend.cjs"]
